{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "typings/**/*.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    "baseUrl": ".",
    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"],
      "/@": ["./node_modules/vome-core/dist/client/index.d.ts"],
      "/@/*": ["./node_modules/vome-core/dist/client/*"],
      "/#": ["./node_modules/vome-core/dist/index.d.ts"],
      "/#/typings/*": ["./node_modules/vome-core/typings/admin/*"],
      "/#/*": ["./node_modules/vome-core/dist/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  },
  "vueCompilerOptions": {
    "globalTypesPath": "./src/auto-imports.d.ts"
  }
}
